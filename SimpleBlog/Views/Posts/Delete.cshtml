@model SimpleBlog.Models.Post

@{
    ViewData["Title"] = "Удалить пост";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Подтверждение удаления поста</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger" role="alert">
                        <i class="bi bi-exclamation-triangle"></i>
                        <strong>Внимание!</strong> Это действие нельзя отменить.
                    </div>

                    <h5>@Model?.Title</h5>
                    <p class="text-muted">
                        <small>Создан: @Model?.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy в HH:mm")</small>
                    </p>
                    <div class="bg-light p-3 rounded mb-3">
                        @Model?.Content
                    </div>

                    <p class="text-danger fw-bold mb-3">Вы уверены, что хотите удалить этот пост?</p>

                    <form method="post" asp-action="DeleteConfirmed" asp-route-id="@Model?.Id" class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger btn-lg">
                            <i class="bi bi-trash"></i> Да, удалить окончательно
                        </button>
                        <a asp-action="Index" class="btn btn-secondary btn-lg">Отмена</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>