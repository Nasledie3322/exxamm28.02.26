@model IEnumerable<SimpleBlog.Models.Post>

@{
    ViewData["Title"] = "Список постов";
}

<div class="container">
    <h2>Посты</h2>

    <a asp-action="Create"><button class="create">Создать пост</button></a>

    <table>
        <thead>
            <tr>
                <th>Id</th>
                <th>Заголовок</th>
                <th>Дата публикации</th>
                <th>Теги</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var post in Model)
            {
                <tr>
                    <td>@post.Id</td>
                    <td>@post.Title</td>
                    <td>@post.PublishedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        @foreach(var pt in post.PostTags)
                        {
                            <span class="badge">@pt.Tag.Name</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@post.Id"><button class="edit">Редактировать</button></a>
                        <a asp-action="Delete" asp-route-id="@post.Id"><button class="delete">Удалить</button></a>
                        <a asp-action="Details" asp-route-id="@post.Id"><button class="create">Просмотр</button></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>