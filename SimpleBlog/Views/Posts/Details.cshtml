@model SimpleBlog.Models.Post

@{
    ViewData["Title"] = @Model?.Title ?? "Пост";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <article class="card">
                <div class="card-header bg-info text-white">
                    <h3 class="mb-0">@Model?.Title</h3>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <small class="text-muted">
                            <i class="bi bi-calendar"></i> 
                            Опубликовано: <strong>@Model?.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy в HH:mm")</strong>
                        </small>
                    </div>

                    <div class="content mb-4 p-3 bg-light rounded">
                        @if (Model?.Content != null)
                        {
                            @Html.Raw(System.Net.WebUtility.HtmlEncode(Model.Content).Replace("\n", "<br/>"))
                        }
                    </div>

                    @if (Model?.PostTags != null && Model.PostTags.Count > 0)
                    {
                        <div class="mb-3">
                            <strong>Теги:</strong>
                            <div class="mt-2">
                                @foreach(var pt in Model.PostTags)
                                {
                                    <span class="badge bg-primary">@pt.Tag?.Name</span>
                                }
                            </div>
                        </div>
                    }
                </div>
                <div class="card-footer bg-light">
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
                        <i class="bi bi-pencil"></i> Редактировать
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Вернуться к постам
                    </a>
                </div>
            </article>
        </div>
    </div>
