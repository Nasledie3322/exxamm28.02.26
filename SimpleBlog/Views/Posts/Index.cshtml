@model IEnumerable<SimpleBlog.Models.Post>

@{
    ViewData["Title"] = "Посты";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Все посты</h2>
        <a asp-action="Create" class="btn btn-success btn-lg">
            <i class="bi bi-plus-circle"></i> Создать новый пост
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 10%;">ID</th>
                        <th style="width: 30%;">Заголовок</th>
                        <th style="width: 20%;">Дата</th>
                        <th style="width: 20%;">Теги</th>
                        <th style="width: 20%;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var post in Model)
                    {
                        <tr>
                            <td><strong>#@post.Id</strong></td>
                            <td><strong>@post.Title</strong></td>
                            <td>@post.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            <td>
                                @foreach(var pt in post.PostTags)
                                {
                                    <span class="badge bg-primary">@pt.Tag?.Name</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@post.Id" class="btn btn-info btn-sm">Просмотр</a>
                                <a asp-action="Edit" asp-route-id="@post.Id" class="btn btn-warning btn-sm">Изменить</a>
                                <a asp-action="Delete" asp-route-id="@post.Id" class="btn btn-danger btn-sm">Удалить</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center" role="alert">
            <h5>Нет постов</h5>
            <p class="mb-0"><a asp-action="Create" class="alert-link">Создайте первый пост</a></p>
        </div>
    }
</div>